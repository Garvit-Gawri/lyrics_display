#include <Wire.h>
#include <LiquidCrystal_I2C.h>

#define LCD_ADDRESS 0x27   // change to 0x3F if 0x27 doesn't work

LiquidCrystal_I2C lcd(LCD_ADDRESS, 16, 2);

const int LCD_WIDTH = 16;
const unsigned long SCROLL_INTERVAL = 400;  // ms between scroll steps - lower = faster
const String GAP = "   ";  // blank gap shown between the end and restart of a loop

String inputBuffer = "";
String rowText[2] = {"", ""};
int scrollPos[2] = {0, 0};
unsigned long lastScrollTime[2] = {0, 0};

void setup() {
  Serial.begin(9600);
  lcd.init();
  lcd.backlight();
  lcd.print("Waiting for");
  lcd.setCursor(0, 1);
  lcd.print("lyrics...");
}

void loop() {
  while (Serial.available() > 0) {
    char c = Serial.read();
    if (c == '\n') {
      processLine(inputBuffer);
      inputBuffer = "";
    } else if (c != '\r') {
      inputBuffer += c;
    }
  }
  updateScroll(0);
  updateScroll(1);
}

void processLine(String data) {
  int sep = data.indexOf('|');
  String l1, l2;
  if (sep >= 0) {
    l1 = data.substring(0, sep);
    l2 = data.substring(sep + 1);
  } else {
    l1 = data;
    l2 = "";
  }
  setRow(0, l1);
  setRow(1, l2);
}

void setRow(int row, String text) {
  rowText[row] = text;
  scrollPos[row] = 0;
  lastScrollTime[row] = millis();
  renderRow(row);
}

void renderRow(int row) {
  lcd.setCursor(0, row);
  String text = rowText[row];
  if (text.length() <= LCD_WIDTH) {
    lcd.print(padTo(text, LCD_WIDTH));
  } else {
    String looped = text + GAP;
    String window = "";
    for (int i = 0; i < LCD_WIDTH; i++) {
      int idx = (scrollPos[row] + i) % looped.length();
      window += looped[idx];
    }
    lcd.print(window);
  }
}

void updateScroll(int row) {
  if (rowText[row].length() <= LCD_WIDTH) return;  // fits fine, no scrolling needed
  unsigned long now = millis();
  if (now - lastScrollTime[row] >= SCROLL_INTERVAL) {
    lastScrollTime[row] = now;
    scrollPos[row] = (scrollPos[row] + 1) % (rowText[row].length() + GAP.length());
    renderRow(row);
  }
}

String padTo(String s, int width) {
  while (s.length() < width) s += ' ';
  return s;
}
